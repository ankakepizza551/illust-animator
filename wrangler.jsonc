{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "illust-animator",
  "compatibility_date": "2026-05-11",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
